{
  "name": "xno-skills",
  "version": "0.6.2",
  "description": "XNO CLI - Interact with the Nano cryptocurrency",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "bin": {
    "xno-skills": "bin/xno-skills",
    "xno-mcp": "bin/xno-mcp"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "preversion": "npm test",
    "version": "node scripts/update-version.js && git add src/version.ts",
    "postversion": "node -e \"const v=require('./package.json').version; console.log('Created tag v'+v+'. Next: git push --follow-tags (GitHub Actions will publish to npm + create the GitHub Release).');\"",
    "prebuild": "node scripts/update-version.js",
    "prebuild:esm": "node scripts/update-version.js",
    "prebuild:cjs": "node scripts/update-version.js",
    "test": "npm run build:esm && vitest run",
    "test:watch": "npm run build:esm && vitest",
    "build": "tsc",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "prepack": "npm run build && npm run build:cjs"
  },
  "keywords": [
    "nano",
    "xno",
    "cryptocurrency",
    "nanocurrency",
    "wallet",
    "bip39",
    "bip44",
    "ed25519",
    "blake2b",
    "blockchain"
  ],
  "author": "Casual Security Inc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CasualSecurityInc/xno-skills.git"
  },
  "bugs": {
    "url": "https://github.com/CasualSecurityInc/xno-skills/issues"
  },
  "homepage": "https://github.com/CasualSecurityInc/xno-skills#readme",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^1.7.0",
    "@scure/bip39": "^2.0.1",
    "commander": "^14.0.3",
    "micro-key-producer": "^0.8.5",
    "qrcode-terminal": "^0.12.0"
  }
}
