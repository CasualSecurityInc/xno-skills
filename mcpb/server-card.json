      "description": "Update the xno-mcp configuration. Any provided fields overwrite existing values; omitted fields are preserved.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
          "rpcUrl": {
            "description": "Primary Nano RPC endpoint URL",
            "type": "string"
          },
          "workPeerUrl": {
            "description": "Remote proof-of-work peer URL",
            "type": "string"
          },
          "timeoutMs": {
            "description": "Request timeout in milliseconds (default: 15000)",
            "type": "number"
          },
          "powTimeoutMs": {
            "description": "Proof-of-work timeout in milliseconds (default: max(timeoutMs * 4, 30000))",
            "type": "number"
          },
          "defaultRepresentative": {
            "description": "Default representative nano_ address for new accounts",
            "type": "string"
          },
          "maxSendXno": {
            "description": "Maximum XNO allowed per send transaction (default: 1.0)",
            "type": "string"
